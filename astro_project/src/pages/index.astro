---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import historiaImg from '../assets/img/historia/img-4.jpg';
import pgOnline from '../assets/img/pgs/pg-online.jpeg';
import pgMulheres from '../assets/img/pgs/mulheres-com-proposito.jpeg';
import pgEnrico from '../assets/img/pgs/pg-enrico.jpeg';
import pgPedro from '../assets/img/pgs/pg-pedro.jpeg';

const API_KEY = import.meta.env.YOUTUBE_API_KEY;
const PLAYLIST_ID = 'UUo1LQoyw17iaoL3y0TnDP9g';
let latestVideoId = 'CMwYG1snm3U'; // Fallback padrão
let latestThumbnail = `https://img.youtube.com/vi/${latestVideoId}/maxresdefault.jpg`;

try {
  if (API_KEY) {
    const res = await fetch(`https://youtube.googleapis.com/youtube/v3/playlistItems?part=snippet&playlistId=${PLAYLIST_ID}&maxResults=1&key=${API_KEY}`);
    if (res.ok) {
        const data = await res.json();
        if (data.items && data.items.length > 0) {
            const item = data.items[0];
            latestVideoId = item.snippet.resourceId.videoId;
            latestThumbnail = item.snippet.thumbnails?.maxres?.url || item.snippet.thumbnails?.high?.url || item.snippet.thumbnails?.medium?.url || `https://img.youtube.com/vi/${latestVideoId}/hqdefault.jpg`;
        }
    }
  }
} catch (e) {
  console.error("Erro ao puxar API do Youtube na Home:", e);
}
---
<Layout title="Primeira Igreja Presbiteriana Independente de Machado" isImmersive={true}>
    <header class="bg-black relative w-full h-[100svh] min-h-[600px] flex flex-col items-center justify-end overflow-hidden pb-16 md:pb-24">
        <!-- Background Video self-hosted -->
        <div class="absolute inset-0 z-0 bg-black pointer-events-none overflow-hidden">
            <video
                autoplay
                muted
                loop
                playsinline
                class="absolute w-full h-full object-cover opacity-90 scale-[1.02]"
                preload="auto"
            >
                <source src="/assets/video/hero.webm" type="video/webm" />
                <source src="/assets/video/hero.mp4" type="video/mp4" />
                <track kind="captions" src="" label="Português" srclang="pt" />
            </video>
            <!-- Sombreamento de base apenas para destacar os botões -->
            <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black via-black/50 to-transparent"></div>
        </div>

        <div class="container mx-auto px-4 lg:px-8 max-w-4xl relative z-10 text-center animate-fade-in-up">
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/visitantes" class="bg-[var(--color-brand)] text-white px-8 py-4 rounded-lg font-bold hover:bg-[var(--color-brand-dark)] transition-colors shadow-2xl hover:-translate-y-1 text-center flex items-center justify-center gap-2 text-lg">
                    <i class="fa-regular fa-calendar-check text-xl"></i> Planeje sua Visita
                </a>
                <a href="#ultimo-culto" class="bg-white/10 backdrop-blur-md text-white px-8 py-4 rounded-lg font-bold hover:bg-white/20 transition-all shadow-sm text-center border border-white/20 hover:border-white/40 text-lg">Mais da Igreja</a>
            </div>
        </div>
        
        <!-- Scroll indicator -->
        <a aria-label="Role para baixo" href="#ultimo-culto" class="absolute bottom-6 left-1/2 transform -translate-x-1/2 flex flex-col items-center animate-bounce text-white/50 hover:text-white select-none hidden lg:flex cursor-pointer no-underline transition-colors z-20">
            <i class="fa-solid fa-chevron-down text-3xl"></i>
        </a>
    </header>


    <!-- ÚLTIMO CULTO SECTION -->
    <section class="py-24 bg-white dark:bg-slate-900 transition-colors relative border-b border-gray-100 dark:border-slate-800" id="ultimo-culto">
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
            <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
                <!-- Text / Info -->
                <div class="w-full lg:w-5/12 scroll-card text-center lg:text-left">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400 text-xs font-bold uppercase tracking-wider mb-6">
                        <span class="relative flex h-2 w-2">
                          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                          <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
                        </span>
                        Aconteceu Recentemente
                    </div>
                    <h2 class="font-extrabold text-3xl md:text-5xl text-gray-900 dark:text-white mb-6 leading-tight">Último Culto</h2>
                    <p class="text-gray-600 dark:text-gray-400 text-lg mb-8 leading-relaxed max-w-xl mx-auto lg:mx-0">
                        Neste domingo nos reunimos na presença de Deus. Se você perdeu ou simplesmente deseja reviver essa mensagem, o culto já está disponível para você assistir na íntegra.
                    </p>
                    <a href="/mensagens" class="inline-flex items-center gap-2 bg-gray-900 dark:bg-white text-gray-100 dark:text-gray-900 px-8 py-4 rounded-lg font-bold hover:bg-black dark:hover:bg-gray-100 transition-colors shadow-md hover:-translate-y-0.5">
                        <i class="fa-solid fa-play text-lg text-[#ff0033]"></i> Ver galeria de mensagens
                    </a>
                </div>
                
                <!-- Video Embed as Button -->
                <div class="w-full lg:w-7/12 scroll-card">
                    <div class="w-full aspect-video rounded-2xl shadow-2xl overflow-hidden ring-1 ring-black/5 dark:ring-white/10 relative group bg-black">
                        <button data-videoid={latestVideoId} class="open-yt-modal relative w-full h-full block focus:outline-none">
                            <img src={latestThumbnail} alt="Último Culto" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                            <div class="absolute inset-0 bg-black/30 group-hover:bg-black/50 transition-colors flex items-center justify-center">
                                <div class="w-16 h-16 bg-[#ff0033] text-white rounded-full flex items-center justify-center opacity-90 group-hover:opacity-100 group-hover:scale-110 shadow-lg transition-transform">
                                    <i class="fa-solid fa-play text-2xl ml-1"></i>
                                </div>
                            </div>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- PRÓXIMO EVENTO -->
    <section class="py-10 bg-gray-50 dark:bg-slate-800 transition-colors border-y border-gray-100 dark:border-slate-700">
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
            <div id="next-event-card" class="rounded-[2.5rem] overflow-hidden shadow-xl scroll-card" style="opacity:0;transition:opacity .5s"></div>
        </div>
    </section>

    <script>
    document.addEventListener('astro:page-load', () => {
        const typeStyle = {
            camp:        { gradient: 'linear-gradient(135deg,#f97316,#dc2626)',   label: 'Acampamento' },
            worship:     { gradient: 'linear-gradient(135deg,#059669,#0d9488)',   label: 'Culto Especial' },
            education:   { gradient: 'linear-gradient(135deg,#2563eb,#4f46e5)',   label: 'Educação' },
            special:     { gradient: 'linear-gradient(135deg,#7c3aed,#6d28d9)',   label: 'Visita Especial' },
            ministry:    { gradient: 'linear-gradient(135deg,#db2777,#e11d48)',   label: 'Ministério' },
            youth:       { gradient: 'linear-gradient(135deg,#0891b2,#0284c7)',   label: 'Juventude' },
            conference:  { gradient: 'linear-gradient(135deg,#0f766e,#047857)',   label: 'Conferência' },
            celebration: { gradient: 'linear-gradient(135deg,#d97706,#b45309)',   label: 'Celebração' },
        };

        const events = [
            { date:'2026-02-14', endDate:'2026-02-17', label:'Acampamento Maanaim', sub:'Temporada de Verão',           type:'camp',        url:'https://acampamaanaim.com.br' },
            { date:'2026-03-14',                       label:'Encontro da Família',  sub:'c/ Rachel Novaes',            type:'special',     url:'/eventos' },
            { date:'2026-04-02', endDate:'2026-04-05', label:'Acampamento Maanaim', sub:'Temporada de Páscoa',          type:'camp',        url:'https://acampamaanaim.com.br' },
            { date:'2026-04-29',                       label:'Culto Especial',       sub:'c/ Hernandes Dias Lopes',     type:'worship',     url:'/eventos' },
            { date:'2026-05-16', endDate:'2026-05-17', label:'Visita do Rev. Sergio Gini', sub:'Presidente da IPI do Brasil', type:'special', url:'/eventos' },
            { date:'2026-06-15',                       label:'Congresso de Casais',  sub:null,                         type:'ministry',    url:'/eventos' },
            { date:'2026-07-04', endDate:'2026-07-05', label:'Educação Reformada',   sub:'c/ Pr. Davi Manso',          type:'education',   url:'/eventos' },
            { date:'2026-07-20', endDate:'2026-07-25', label:'Semana Jovem 2026',    sub:null,                         type:'youth',       url:'/eventos' },
            { date:'2026-08-22', endDate:'2026-08-25', label:'Acampamento Maanaim', sub:'Temporada de Festa',           type:'camp',        url:'https://acampamaanaim.com.br' },
            { date:'2026-09-04', endDate:'2026-09-06', label:'Conferência da Fé Reformada', sub:null,                  type:'conference',  url:'/eventos' },
            { date:'2026-09-15',                       label:'152 Anos da 1IPIM',    sub:'Culto especial c/ Vitor Quevedo', type:'celebration', url:'/eventos' },
            { date:'2026-10-01',                       label:'Acampamento Maanaim', sub:'Temporada Kids',               type:'camp',        url:'https://acampamaanaim.com.br' },
            { date:'2026-10-23', endDate:'2026-10-25', label:'Conferência Missionária', sub:null,                      type:'conference',  url:'/eventos' },
            { date:'2026-11-20',                       label:'Cultos de Formatura',  sub:null,                         type:'celebration', url:'/eventos' },
            { date:'2026-12-25',                       label:'Culto de Natal',       sub:null,                         type:'celebration', url:'/eventos' },
            { date:'2026-12-31',                       label:'Culto de Ano Novo',    sub:null,                         type:'celebration', url:'/eventos' },
        ];

        const parseDate = (s) => {
            const [y, m, d] = s.split('-').map(Number);
            return new Date(y, m - 1, d);
        };

        const card = document.getElementById('next-event-card');
        if (!card) return;

        const today = new Date(); today.setHours(0,0,0,0);
        const next = events
            .map(e => ({ ...e, _end: parseDate(e.endDate || e.date) }))
            .filter(e => e._end >= today)
            .sort((a,b) => parseDate(a.date).getTime() - parseDate(b.date).getTime())[0];

        if (!next) { card.parentElement?.closest('section')?.remove(); return; }

        const st = typeStyle[next.type] || typeStyle.celebration;

        // Format date label
        const start = parseDate(next.date);
        const fmt = (d) => d.toLocaleDateString('pt-BR', { day:'numeric', month:'long', year:'numeric' });
        const dateLabel = next.endDate
            ? `${start.getDate()} a ${fmt(parseDate(next.endDate))}`
            : fmt(start);

        card.innerHTML = `
            <div style="background:${st.gradient}" class="text-white p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-8 relative overflow-hidden">
                <div class="absolute right-0 top-0 w-[400px] h-[400px] bg-white/5 rounded-full blur-[100px] pointer-events-none -translate-y-1/3 translate-x-1/3"></div>
                <div class="absolute left-0 bottom-0 w-64 h-64 bg-black/10 rounded-full blur-[60px] pointer-events-none translate-y-1/3 -translate-x-1/3"></div>

                <div class="text-center md:text-left relative z-10">
                    <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm text-white/90 text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full mb-5">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-white"></span>
                        </span>
                        ${st.label} &nbsp;·&nbsp; Próximo Evento
                    </div>
                    <h3 class="font-extrabold text-3xl md:text-4xl lg:text-5xl mb-2 drop-shadow leading-tight">${next.label}</h3>
                    ${next.sub ? `<p class="text-white/75 text-lg font-medium mb-3">${next.sub}</p>` : ''}
                    <p class="text-white/60 text-sm font-semibold tracking-wide mt-2"><i class="fa-regular fa-calendar mr-2"></i>${dateLabel}</p>
                </div>

                    <div class="flex flex-col items-center gap-4 relative z-10 shrink-0">
                        <div class="flex items-end gap-3 md:gap-4">
                            <div class="text-center">
                                <div id="cnt-days" class="font-black text-5xl md:text-6xl tabular-nums leading-none drop-shadow-xl">--</div>
                                <div class="text-white/55 text-[10px] font-bold uppercase tracking-widest mt-1.5">dias</div>
                            </div>
                            <div class="font-black text-3xl text-white/30 mb-3">:</div>
                            <div class="text-center">
                                <div id="cnt-hours" class="font-black text-5xl md:text-6xl tabular-nums leading-none drop-shadow-xl">--</div>
                                <div class="text-white/55 text-[10px] font-bold uppercase tracking-widest mt-1.5">horas</div>
                            </div>
                            <div class="font-black text-3xl text-white/30 mb-3">:</div>
                            <div class="text-center">
                                <div id="cnt-mins" class="font-black text-5xl md:text-6xl tabular-nums leading-none drop-shadow-xl">--</div>
                                <div class="text-white/55 text-[10px] font-bold uppercase tracking-widest mt-1.5">min</div>
                            </div>
                        </div>

                        ${next.url.startsWith('http') ? `
                            <div class="flex flex-col items-center gap-3">
                                <a href="${next.url}" target="_blank" rel="nofollow" class="inline-flex items-center gap-2 bg-white text-gray-900 border border-transparent px-8 py-3.5 rounded-full font-bold transition-all duration-300 text-sm hover:-translate-y-0.5 shadow-xl hover:bg-gray-100">
                                    Inscrições e Informações <i class="fa-solid fa-arrow-up-right-from-square text-xs opacity-70"></i>
                                </a>
                                <a href="/eventos" class="text-white/60 hover:text-white text-xs font-bold transition-colors border-b border-white/20 hover:border-white pb-0.5">
                                    Ver calendário completo da igreja
                                </a>
                            </div>
                        ` : `
                            <a href="/eventos" class="inline-flex items-center gap-2 bg-white/15 hover:bg-white text-white hover:text-gray-900 backdrop-blur-sm border border-white/30 hover:border-transparent px-7 py-3 rounded-full font-bold transition-all duration-300 text-sm hover:-translate-y-0.5 shadow-lg">
                                Ver calendário completo <i class="fa-solid fa-arrow-right"></i>
                            </a>
                        `}
                    </div>
            </div>
        `;
        card.style.opacity = '1';

        function tick() {
            const target = parseDate(next.date); target.setHours(19,0,0,0);
            const diff = target.getTime() - Date.now();
            if (diff <= 0) {
                const cntDays = document.getElementById('cnt-days');
                const cntHours = document.getElementById('cnt-hours');
                const cntMins = document.getElementById('cnt-mins');
                if (cntDays) cntDays.textContent = '00';
                if (cntHours) cntHours.textContent = '00';
                if (cntMins) cntMins.textContent = '00';
                return;
            }
            const d = Math.floor(diff / 86400000);
            const h = Math.floor((diff % 86400000) / 3600000);
            const m = Math.floor((diff % 3600000) / 60000);
            const pad = n => String(n).padStart(2,'0');
            const dEl = document.getElementById('cnt-days');
            const hEl = document.getElementById('cnt-hours');
            const mEl = document.getElementById('cnt-mins');
            if (dEl) dEl.textContent = pad(d);
            if (hEl) hEl.textContent = pad(h);
            if (mEl) mEl.textContent = pad(m);
        }
        tick();
        if (!window._nextEventTimer) window._nextEventTimer = setInterval(tick, 30000);
    });
    </script>

    <section class="py-24 relative bg-[var(--color-brand)] dark:bg-[var(--color-brand-dark)] overflow-hidden transition-colors">
        <!-- Decoration -->
        <div class="absolute inset-0 opacity-10 mix-blend-overlay" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 32px 32px;"></div>
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl relative z-10">
            <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
                <div class="w-full lg:w-1/2 text-center lg:text-left scroll-card">
                    <p class="font-bold text-green-100 mb-2 uppercase tracking-wide text-xs">Nossos Grupos</p>
                    <h2 class="font-extrabold text-3xl md:text-5xl text-white mb-6 leading-tight">A vida é melhor vivida em comunidade.</h2>
                    <p class="text-white/80 text-lg mb-8 leading-relaxed max-w-xl mx-auto lg:mx-0">
                        Pequenos Grupos são o coração da nossa igreja. Eles são encontros semanais em lares para compartilhar a vida, estudar a Palavra e orar juntos. Há um grupo cheio de carinho na sua vizinhança!
                    </p>
                    <a href="/pg" class="inline-flex items-center gap-2 bg-white text-[var(--color-brand)] px-8 py-4 rounded-lg font-bold hover:bg-gray-50 transition-colors shadow-lg hover:-translate-y-1">
                        Encontre sua Comunidade <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
                <div class="w-full lg:w-1/2 scroll-card">
                    <div class="grid grid-cols-2 gap-4">
                        <div class="space-y-4 mt-12">
                            <Image src={pgOnline} alt="Pequeno Grupo em Casa" width={400} height={500} class="rounded-2xl shadow-2xl w-full h-[220px] object-cover ring-4 ring-white/10" />
                            <Image src={pgMulheres} alt="Pessoas sorrindo" width={400} height={500} class="rounded-2xl shadow-2xl w-full h-[280px] object-cover ring-4 ring-white/10" />
                        </div>
                        <div class="space-y-4">
                            <Image src={pgEnrico} alt="Grupo de jovens" width={400} height={500} class="rounded-2xl shadow-2xl w-full h-[280px] object-cover ring-4 ring-white/10" />
                            <Image src={pgPedro} alt="Estudo bíblico" width={400} height={500} class="rounded-2xl shadow-2xl w-full h-[220px] object-cover ring-4 ring-white/10" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="sobre-nos" class="py-24 relative bg-gray-50 dark:bg-slate-900 transition-colors">
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
            <div class="text-center max-w-2xl mx-auto mb-16 scroll-card">
                <p class="font-bold text-[var(--color-success)] mb-2 uppercase tracking-wide text-xs">A nossa identidade</p>
                <h3 class="font-extrabold text-3xl md:text-4xl text-gray-900 dark:text-white">Conheça a 1IPIM</h3>
            </div>

            <!-- Slogan Highlight -->
            <div class="text-center scroll-card px-4 mb-20">
                <div class="relative inline-block px-10 md:px-16">
                    <!-- Aspas com contraste reforçado -->
                    <span class="absolute -top-8 left-0 md:-left-4 text-amber-500/60 dark:text-amber-400/50 text-5xl md:text-7xl select-none">
                        <i class="fa-solid fa-quote-left"></i>
                    </span>
                    <h2 class="font-medium text-xl md:text-2xl lg:text-3xl text-[var(--color-brand)] dark:text-[var(--color-brand-light)] italic tracking-tight leading-tight max-w-4xl mx-auto py-4">
                        Mais de um século perseverando e propagando a Palavra
                    </h2>
                    <span class="absolute -bottom-4 right-0 md:-right-4 text-amber-500/60 dark:text-amber-400/50 text-5xl md:text-7xl select-none">
                        <i class="fa-solid fa-quote-right"></i>
                    </span>
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto auto-rows-min">
                <!-- Bento Block: Missão -->
                <div class="bg-white dark:bg-slate-800 rounded-3xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 scroll-card border border-gray-100 dark:border-slate-700 flex flex-col items-start group">
                    <div class="w-12 h-12 bg-amber-50 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400 rounded-2xl flex items-center justify-center mb-6 border border-amber-100 dark:border-amber-800/50 group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-bullseye text-xl"></i>
                    </div>
                    <h5 class="font-bold text-xl text-gray-900 dark:text-white mb-2">Nossa Missão</h5>
                    <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">
                        Perseverar na doutrina, na comunhão, no partir do pão e nas orações.
                    </p>
                </div>

                <!-- Bento Block: Visão -->
                <div class="bg-white dark:bg-slate-800 rounded-3xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 scroll-card border border-gray-100 dark:border-slate-700 md:col-span-2 flex flex-col items-start group">
                    <div class="w-12 h-12 bg-emerald-50 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 rounded-2xl flex items-center justify-center mb-6 border border-emerald-100 dark:border-emerald-800/50 group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-eye text-xl"></i>
                    </div>
                    <h5 class="font-bold text-xl text-gray-900 dark:text-white mb-2">Nossa Visão</h5>
                    <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">
                        Ser uma igreja missionária que equipa seus membros, por meio da Palavra, para o cumprimento do "Ide e fazei discípulos".
                    </p>
                </div>

                <!-- Bento Block 1: História (Large/Tall) -->
                <div class="bg-white dark:bg-slate-800 rounded-3xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 scroll-card border border-gray-100 dark:border-slate-700 md:col-span-2 md:row-span-2 relative overflow-hidden group flex flex-col justify-end min-h-[300px] md:min-h-[400px]">
                    <div class="absolute inset-0">
                        <Image src={historiaImg} alt="História da igreja" width={800} height={600} class="w-full h-full object-cover opacity-60 dark:opacity-40 group-hover:scale-105 transition-transform duration-700 object-center" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/10"></div>
                    </div>
                    <h5 class="font-bold text-2xl text-white relative z-10 mb-2 drop-shadow-lg">A nossa História</h5>
                    <p class="text-gray-200 text-sm relative z-10 mb-6 max-w-md drop-shadow">Conheça nossa trajetória centenária até os dias de hoje através dos milagres e da palavra de Deus.</p>
                    <a href="/historia" class="inline-flex w-max items-center bg-white text-gray-900 px-6 py-2.5 rounded-full text-sm font-bold shadow-lg hover:scale-105 transition-transform relative z-10">Ler a história detalhada <i class="fa-solid fa-arrow-right ml-2 text-xs"></i></a>
                </div>

                <!-- Bento Block 2: Cremos (Square) -->
                <div class="bg-gradient-to-br from-[var(--color-brand)] to-[var(--color-brand-dark)] rounded-3xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 scroll-card md:col-span-1 md:row-span-1 flex flex-col items-start justify-center text-white relative group overflow-hidden">
                    <div class="absolute -right-6 -top-6 text-white/10 text-9xl group-hover:rotate-12 transition-transform duration-500">
                        <i class="fa-solid fa-book-bible"></i>
                    </div>
