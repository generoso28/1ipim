---
import Layout from '../layouts/Layout.astro';

const congregacoes = [
    { name: "Santa Luíza", address: "R. Ituiutaba, 58", city: "Santa Luiza, Machado-MG" },
    { name: "Jardim das Oliveiras", address: "R. Augusto Buzatti Filho, 204", city: "Jd. das Oliveiras, Machado-MG" },
    { name: "Santo Antônio II", address: "R. José Cândido de Souza Dias,", city: "Santo Antônio II, Machado-MG" },
    { name: "Serrania", address: "R. Cel. Antônio Faustino, 450", city: "Serrania-MG" },
    { name: "Paraguaçu", address: "Av. Dr. Domingos Condé, 70", city: "Parque dos Pinheiros, Paraguaçu-MG" },
    { name: "Carvalhópolis", address: "R. Marcolino Pereira de Carvalho, 385", city: "Carvalhópolis-MG" },
    { name: "Pouso Alegre", address: "R. Coronel José Inacio, 290", city: "Jardim Noronha, Pouso Alegre-MG" }
];
---
<Layout title="Contato - Primeira Igreja Presbiteriana Independente de Machado">
    <section class="py-20 mt-16 bg-white dark:bg-slate-900 transition-colors min-h-screen">
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
            <div class="text-center max-w-2xl mx-auto mb-16 scroll-card">
                <p class="font-bold text-[var(--color-success)] mb-2 uppercase tracking-wide text-sm">Contato</p>
                <h2 class="font-extrabold text-3xl md:text-4xl text-gray-900 dark:text-white mb-2">Saiba como entrar em contato</h2>
            </div>

            <div class="flex flex-col lg:flex-row gap-8 mb-16">
                <!-- Sede Contact Info -->
                <div class="w-full lg:w-1/3 bg-gray-50 dark:bg-slate-800 rounded-2xl p-8 border border-gray-100 dark:border-slate-700 shadow-sm scroll-card h-full flex flex-col">
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">Sede</h2>
                    
                    <div class="space-y-8 flex-1">
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 rounded-full bg-[var(--color-brand)]/10 text-[var(--color-brand)] flex items-center justify-center shrink-0 shadow-sm">
                                <i class="fa-solid fa-phone"></i>
                            </div>
                            <div>
                                <h6 class="font-bold text-gray-900 dark:text-gray-100 mb-1">Telefone</h6>
                                <p class="text-gray-600 dark:text-gray-300 m-0">(35) 3295-1862<br/>(35) 98861-3046</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 rounded-full bg-[var(--color-brand)]/10 text-[var(--color-brand)] flex items-center justify-center shrink-0 shadow-sm">
                                <i class="fa-solid fa-envelope"></i>
                            </div>
                            <div>
                                <h6 class="font-bold text-gray-900 dark:text-gray-100 mb-1">Email</h6>
                                <p class="text-gray-600 dark:text-gray-300 m-0"><a href="mailto:secretaria1ipi@gmail.com" class="hover:text-[var(--color-brand)] transition-colors">secretaria1ipi@gmail.com</a></p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 rounded-full bg-[var(--color-brand)]/10 text-[var(--color-brand)] flex items-center justify-center shrink-0 shadow-sm">
                                <i class="fa-solid fa-location-dot"></i>
                            </div>
                            <div>
                                <h6 class="font-bold text-gray-900 dark:text-gray-100 mb-1">Endereço</h6>
                                <p class="text-gray-600 dark:text-gray-300 m-0">R. Airton Rodrigues Leite, 26 - Centro<br/>Machado, MG</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Google Maps -->
                <div class="w-full lg:w-2/3 h-[400px] lg:h-auto min-h-[400px] rounded-2xl overflow-hidden shadow-sm border border-gray-100 dark:border-slate-700 scroll-card">
                    <iframe title="Mapa de localização" class="w-full h-full" src="https://maps.google.com/maps?width=100%25&amp;height=100%25&amp;hl=en&amp;q=Rua%20Airton%20Rodrigues%20Leite,%2026&amp;t=&amp;z=17&amp;ie=UTF8&amp;iwloc=B&amp;output=embed"></iframe>
                </div>
            </div>

            <div class="mt-16">
                <h3 class="font-bold text-3xl text-gray-900 dark:text-white mb-10 text-center scroll-card">Nossas Congregações</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                    {congregacoes.map(cong => (
                        <div class="bg-gray-50 dark:bg-slate-800 rounded-2xl p-6 md:p-8 border border-gray-100 dark:border-slate-700 shadow-sm hover:shadow-md transition-shadow scroll-card flex flex-col h-full group">
                            <h2 class="text-xl font-bold text-[var(--color-brand)] dark:text-[var(--color-brand-light)] mb-6 group-hover:text-[var(--color-brand-dark)] dark:group-hover:text-[var(--color-brand)] transition-colors">{cong.name}</h2>
                            <div class="mt-auto">
                                <h6 class="font-bold text-gray-900 dark:text-gray-200 text-sm mb-1 uppercase tracking-wide">Endereço</h6>
                                <p class="text-gray-600 dark:text-gray-400 text-sm mb-0">{cong.address}<br/>{cong.city}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>

        </div>
    </section>
</Layout>
