---
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
    isImmersive?: boolean;
}

const { title, description = "Igreja Presbiteriana Independente de Machado – Há 150 anos servindo a Deus e à comunidade.", image = "/assets/img/historia/150anos1.webp", isImmersive = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-br" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />
    <title>{title}</title>
    
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site || 'https://1ipim.online')} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:type" content="website" />
    <meta name="robots" content="index, follow" />
    
    <link rel="canonical" href={Astro.url} />
    <link rel="icon" type="image/png" href="/assets/img/logo_transp.png" />
    <link rel="icon" type="image/x-icon" href="/assets/img/logo_transp.ico" />
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" />
    
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script is:inline src="/assets/js/scroll.js"></script>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Church",
      "name": "Igreja Presbiteriana Independente de Machado",
      "url": "https://1ipim.online",
      "logo": "https://1ipim.online/assets/img/logo_transp.png",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+55-35-98861-3046",
        "contactType": "Inquiries",
        "areaServed": "BR",
        "availableLanguage": "Portuguese"
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Rua Airton Rodrigues Leite, 26",
        "addressLocality": "Machado",
        "addressRegion": "Minas Gerais",
        "postalCode": "37700-000",
        "addressCountry": "BR"
      },
      "sameAs": [
        "https://www.instagram.com/1ipim",
        "https://www.youtube.com/@1ipimachado"
      ]
    }
    </script>
    <script is:inline>
        const theme = (() => {
            if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                return localStorage.getItem('theme');
            }
            if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                return 'dark';
            }
            return 'light';
        })();
        
        if (theme === 'light') {
            document.documentElement.classList.remove('dark');
        } else {
            document.documentElement.classList.add('dark');
        }
        window.localStorage.setItem('theme', theme);

        // Keep theme sync after view transitions
        document.addEventListener('astro:after-swap', () => {
             if (localStorage.getItem('theme') === 'dark') {
                 document.documentElement.classList.add('dark');
             }
        });
    </script>
    <ClientRouter />
</head>
<body class="font-['Inter'] antialiased text-gray-800 bg-gray-50 dark:bg-slate-900 dark:text-gray-100 transition-colors duration-300 overflow-x-hidden">
    <Navbar isImmersive={isImmersive} />
    <main>
        <slot />
    </main>
    <Footer />
    
    <!-- YouTube Modal Pop-up Global -->
    <div id="yt-modal" class="fixed inset-0 z-[2000] hidden bg-black/90 backdrop-blur-sm flex-col items-center justify-center p-4 sm:p-8 opacity-0 transition-opacity duration-300">
        <div class="relative w-full max-w-5xl aspect-video bg-black rounded-xl overflow-hidden shadow-2xl ring-1 ring-white/20 transform scale-95 transition-transform duration-300" id="yt-modal-content">
            <button id="close-modal" aria-label="Fechar vídeo" class="absolute top-4 right-4 text-white hover:text-white bg-black/50 hover:bg-[#ff0033] rounded-full w-10 h-10 flex items-center justify-center transition-all z-[2010]">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
            <iframe id="yt-iframe" class="w-full h-full" src="" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
        </div>
    </div>

    <script>
        document.addEventListener('astro:page-load', () => {
            const btns = document.querySelectorAll('.open-yt-modal');
            const modal = document.getElementById('yt-modal');
            const iframe = document.getElementById('yt-iframe');
            const closeBtn = document.getElementById('close-modal');
            const modalContent = document.getElementById('yt-modal-content');

            if (!modal || !iframe) return;

            const closeModal = () => {
                modal.classList.add('opacity-0');
                modalContent?.classList.add('scale-95');
                modalContent?.classList.remove('scale-100');
                setTimeout(() => {
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                    iframe.src = ""; // Stop video playing immediately
                }, 300);
            };

            btns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const target = e.currentTarget;
                    const videoId = target.getAttribute('data-videoid');
                    
                    if (videoId && iframe) {
                        iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
                        modal.classList.remove('hidden');
                        modal.classList.add('flex');
                        
                        setTimeout(() => {
                            modal.classList.remove('opacity-0');
                            modalContent?.classList.remove('scale-95');
                            modalContent?.classList.add('scale-100');
                        }, 10);
                    }
                });
            });

            closeBtn?.addEventListener('click', closeModal);
            modal.addEventListener('click', (e) => {
                if (e.target === modal) closeModal();
            });
            
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
                    closeModal();
                }
            });
        });
    </script>
</body>
</html>
