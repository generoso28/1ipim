---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

const pilares = [
    {
        title: "Doutrina",
        color: "#7ccece",
        image: "/assets/img/cremos/doutrina.jpg",
        text: "Cremos que todo cristão deve estar ancorado na Palavra de Deus, na sã doutrina dos apóstolos. Zelamos pelo ensino fiel das Escrituras, reconhecendo que a verdade revelada é a base para a vida cristã e a edificação da Igreja. A doutrina dos apóstolos é nossa guia e fundamento, sendo a autoridade final para fé e prática.",
        reverse: false
    },
    {
        title: "Comunhão",
        color: "#6fc7b0",
        image: "/assets/img/cremos/comunhao.jpg",
        text: "Cremos que a comunhão entre os cristãos é vital para a vida da Igreja. Acreditamos na importância do apoio mútuo, do cuidado e da edificação dos irmãos em Cristo. A comunhão reflete o amor de Deus e deve ser uma marca visível em nosso relacionamento, sendo expressão da unidade do corpo de Cristo.",
        reverse: true
    },
    {
        title: "Partir do pão",
        color: "#beeb69",
        image: "/assets/img/cremos/ceia.jpg",
        text: "Cremos que a Ceia do Senhor é um meio sagrado de lembrar e proclamar a morte de Cristo até que Ele venha. Ao partirmos do pão, somos fortalecidos na fé, renovamos nossa comunhão com Cristo e com a Igreja, e expressamos nossa dependência de Sua obra redentora.",
        reverse: false
    },
    {
        title: "Orações",
        color: "#7bcfa0",
        image: "/assets/img/cremos/oracoes.jpg",
        text: "Cremos que a oração é o pilar da Igreja, essencial para o crescimento espiritual do cristão e para a comunhão com Deus. Por meio da oração, buscamos a direção divina, intercedemos uns pelos outros e expressamos nossa total dependência do Senhor. Como Igreja, perseveramos na oração, confiantes no poder e na fidelidade de Deus.",
        reverse: true
    }
];

const subscrevemos = [
    {
        title: "Confissão de fé de Westminster",
        image: "/assets/img/cremos/Westminster.webp",
        text: "A <strong>Confissão de Fé de Westminster</strong> (1646) é um dos principais documentos reformados, sistematizando doutrinas como a autoridade das Escrituras, a soberania de Deus, a salvação pela graça e a organização da Igreja. Redigida por teólogos puritanos, tornou-se a base teológica de muitas igrejas presbiterianas ao redor do mundo.",
        link: "https://ipib.org.br/confissao-de-fe-de-westminster/",
        buttonText: "Leia",
        reverse: false
    },
    {
        title: "Constituição da IPI do Brasil",
        image: "/assets/img/cremos/catedral.jpg",
        text: "A <strong>Constituição da IPI do Brasil</strong> define sua identidade reformada, governo presbiteriano e organização em igreja local, presbitério, sínodo e Assembleia Geral. Regula ofícios ministeriais, disciplina e administração, seguindo a Confissão de Fé de Westminster.",
        link: "https://drive.google.com/file/d/10czyUbZbkKe67QQcWLXoKN2CA1dCXCJP/view?usp=sharing",
        buttonText: "Acesse",
        reverse: true
    }
];
---
<Layout title="O que cremos? - Primeira Igreja Presbiteriana Independente de Machado">
    <section class="py-20 mt-16 bg-white dark:bg-slate-900 transition-colors overflow-hidden">
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
            <div class="text-center max-w-2xl mx-auto mb-16 scroll-card">
                <p class="font-bold text-[var(--color-success)] mb-2 uppercase tracking-wide text-sm">Sobre nós</p>
                <h3 class="font-extrabold text-3xl md:text-4xl text-gray-900 dark:text-white mb-6">As quatro cores da igreja</h3>
                <p class="text-gray-500 dark:text-gray-400 text-lg md:px-12 italic leading-relaxed">
                    'E perseveravam na doutrina dos apóstolos e na comunhão, no partir do pão e nas orações.'<br/>Atos 2:42
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto">
                {pilares.map(pilar => (
                    <div class="rounded-[2rem] p-8 lg:p-10 shadow-lg hover:shadow-2xl transition-all duration-500 overflow-hidden relative group flex flex-col justify-end min-h-[400px] md:min-h-[500px] border border-gray-100 dark:border-slate-800 scroll-card">
                        <div class="absolute inset-0 z-0">
                            <Image src={pilar.image} alt={pilar.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000 opacity-90 dark:opacity-50" loading="lazy" width={800} height={800} />
                            <!-- Novo degradê poderoso de baixo para cima -->
                            <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/80 to-transparent"></div>
                            <!-- Máscara superior suave -->
                            <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors duration-500"></div>
                        </div>
                        <div class="relative z-10 translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                            <h5 class="font-extrabold text-3xl lg:text-4xl mb-4 drop-shadow-md" style={`color: ${pilar.color};`}>{pilar.title}</h5>
                            <p class="text-gray-200 text-sm lg:text-base leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100 h-0 group-hover:h-auto overflow-hidden text-shadow-lg drop-shadow">{pilar.text}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section class="py-20 bg-gray-50 dark:bg-slate-800 border-t border-gray-100 dark:border-slate-800 transition-colors overflow-hidden">
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
            <div class="text-center max-w-2xl mx-auto mb-16 scroll-card">
                <p class="font-bold text-[var(--color-success)] mb-2 uppercase tracking-wide text-sm">Além disso</p>
                <h3 class="font-extrabold text-3xl md:text-4xl text-gray-900 dark:text-white">Também subscrevemos</h3>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
                {subscrevemos.map(sub => (
                    <div class="bg-gray-100 dark:bg-slate-700 rounded-[2.5rem] p-8 lg:p-12 shadow-md hover:shadow-xl transition-all duration-300 scroll-card flex flex-col justify-between group overflow-hidden relative min-h-[400px]">
                        <div class="absolute right-0 top-0 w-64 h-64 bg-[var(--color-brand)]/10 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/2 pointer-events-none group-hover:scale-150 transition-transform duration-1000"></div>
                        <div class="relative z-10">
                            <div class="w-16 h-16 bg-white dark:bg-slate-800 rounded-2xl flex items-center justify-center mb-6 shadow-sm group-hover:rotate-12 group-hover:scale-110 transition-transform">
                                <i class="fa-solid fa-file-contract text-2xl text-[var(--color-brand-dark)] dark:text-[var(--color-brand-light)]"></i>
                            </div>
                            <h5 class="font-extrabold text-2xl lg:text-3xl text-gray-900 dark:text-white mb-4 leading-tight">{sub.title}</h5>
                            <div class="text-gray-600 dark:text-gray-300 mb-8 leading-relaxed text-sm lg:text-base prose dark:prose-invert" set:html={sub.text}></div>
                        </div>
                        <a href={sub.link} target="_blank" rel="nofollow" class="relative z-10 mt-auto inline-flex items-center gap-2 bg-gray-900 dark:bg-white text-white dark:text-gray-900 px-8 py-4 rounded-full font-bold hover:bg-black dark:hover:bg-gray-100 transition-all shadow-lg hover:-translate-y-1 w-max">
                            {sub.buttonText} <i class="fa-solid fa-arrow-up-right-from-square text-xs opacity-70"></i>
                        </a>
                    </div>
                ))}
            </div>
        </div>
    </section>
</Layout>
