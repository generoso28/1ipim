---
import { Image } from 'astro:assets';
const currentPath = Astro.url.pathname;

const links = [
    { href: "/", text: "Home" },
    { href: "/programacao", text: "Programação" },
    { href: "/eventos", text: "Eventos" },
    { href: "/pg", text: "Pequenos Grupos" },
    { href: "/pastores", text: "Pastores" },
    { href: "/cremos", text: "O que cremos?" },
    { href: "/historia", text: "Nossa história" },
    { href: "/mensagens", text: "Mensagens" },
    { href: "/visitantes", text: "Primeira Vez?", special: true }
];
const { isImmersive = false } = Astro.props || {};
---
<nav class={`fixed top-0 left-0 w-full z-[1000] transition-all duration-700 pt-3 md:pt-5 px-4 pointer-events-none ${isImmersive ? 'opacity-0 -translate-y-[150%] is-immersive' : ''}`} id="mainNav">
    <div class="container mx-auto px-6 py-3 flex justify-between items-center max-w-7xl bg-white/90 dark:bg-slate-900/90 backdrop-blur-lg rounded-2xl xl:rounded-full shadow-lg border border-white/50 dark:border-slate-700/50 pointer-events-auto transition-colors">
        <a class="flex justify-center items-center shrink-0" href="/">
            <Image alt="Logo da igreja" class="max-w-[40px] h-auto hover:scale-105 transition-transform drop-shadow-sm" src="/assets/img/logo_transp.png" width="40" height="40" loading="eager" />
        </a>
        
        <div class="flex items-center space-x-2 md:space-x-6 lg:space-x-8">
            <div class="hidden xl:flex items-center space-x-8">
                {links.map(link => (
                    link.special ? (
                        <a href={link.href} class="bg-[var(--color-brand)] text-white px-5 py-2.5 rounded-lg font-bold hover:bg-[var(--color-brand-dark)] transition-colors shadow-md animate-pulse hover:animate-none flex items-center gap-2">
                            <i class="fa-solid fa-hand-wave"></i> {link.text}
                        </a>
                    ) : (
                        <a 
                            href={link.href} 
                            class={`font-medium transition-colors hover:text-[var(--color-brand)] dark:hover:text-[var(--color-brand-light)] text-sm ${currentPath === link.href || (currentPath === '/' && link.href === '/') ? 'text-[var(--color-brand)] dark:text-[var(--color-brand-light)]' : 'text-gray-600 dark:text-gray-300'}`}
                        >
                            {link.text}
                        </a>
                    )
                ))}
            </div>

            <button id="theme-toggle" type="button" aria-label="Alternar tema" class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-800 focus:outline-none rounded-lg text-sm p-2 transition-colors">
                <i id="theme-toggle-dark-icon" class="fa-solid fa-moon hidden text-lg"></i>
                <i id="theme-toggle-light-icon" class="fa-solid fa-sun hidden text-lg"></i>
            </button>
            
            <div class="xl:hidden flex">
                <!-- Mobile Menu Button -->
                <button id="mobile-menu-btn" aria-label="Menu" class="p-2 text-gray-600 dark:text-gray-300 hover:text-[var(--color-brand)] dark:hover:text-[var(--color-brand-light)] focus:outline-none transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
            </div>
        </div>
    </div>
    
    <!-- Mobile Menu Content -->
    <div class="container mx-auto px-0 max-w-7xl pointer-events-auto">
        <div id="mobile-menu" class="xl:hidden hidden bg-white/95 dark:bg-slate-900/95 backdrop-blur-xl border border-white/20 dark:border-slate-700/50 mt-2 absolute w-[calc(100%-2rem)] md:w-full left-4 md:left-0 px-4 py-4 rounded-2xl shadow-2xl transition-all duration-300 z-[900]">
            <div class="flex flex-col space-y-1">
                {links.map(link => (
                    <a 
                        href={link.href} 
                        class={`block py-3 px-4 rounded-xl font-medium transition-all duration-200 hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-[var(--color-brand)] dark:hover:text-[var(--color-brand-light)] hover:pl-6 ${currentPath === link.href ? 'text-[var(--color-brand)] dark:text-[var(--color-brand-light)] bg-gray-50 dark:bg-slate-800/80' : 'text-gray-700 dark:text-gray-200'}`}
                    >
                        {link.special ? <span class="flex items-center gap-2 text-[var(--color-brand)] font-bold"><i class="fa-solid fa-hand-wave"></i> {link.text}</span> : link.text}
                    </a>
                ))}
            </div>
        </div>
    </div>
</nav>

<script>
    // Usa 'astro:page-load' no lugar de 'DOMContentLoaded' para SPA view transitions
    document.addEventListener('astro:page-load', () => {
        const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
        const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
        const themeToggleBtn = document.getElementById('theme-toggle');

        if (themeToggleBtn && themeToggleDarkIcon && themeToggleLightIcon) {
            let currentTheme = localStorage.getItem('theme');
            if (currentTheme === 'dark' || (!currentTheme && document.documentElement.classList.contains('dark'))) {
                themeToggleLightIcon.classList.remove('hidden');
                themeToggleDarkIcon.classList.add('hidden');
            } else {
                themeToggleDarkIcon.classList.remove('hidden');
                themeToggleLightIcon.classList.add('hidden');
            }

            themeToggleBtn.onclick = () => {
                const isDark = document.documentElement.classList.toggle('dark');
                if (isDark) {
                    localStorage.setItem('theme', 'dark');
                    themeToggleLightIcon.classList.remove('hidden');
                    themeToggleDarkIcon.classList.add('hidden');
                } else {
                    localStorage.setItem('theme', 'light');
                    themeToggleDarkIcon.classList.remove('hidden');
                    themeToggleLightIcon.classList.add('hidden');
                }
            };
        }

        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        if (btn && menu) {
            btn.onclick = () => {
                menu.classList.toggle('hidden');
            };
        }

        const mainNav = document.getElementById('mainNav');
        if (mainNav && mainNav.classList.contains('is-immersive')) {
            const handleScroll = () => {
                if (window.scrollY > window.innerHeight * 0.7) {
                    mainNav.classList.remove('opacity-0', '-translate-y-[150%]', 'pointer-events-none');
                } else {
                    mainNav.classList.add('opacity-0', '-translate-y-[150%]', 'pointer-events-none');
                }
            };
            window.addEventListener('scroll', handleScroll, { passive: true });
            handleScroll();
        }
    });
</script>
