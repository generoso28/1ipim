---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
---
<Layout title="Primeira Igreja Presbiteriana Independente de Machado">
    <header class="bg-white dark:bg-slate-900 transition-colors w-full min-h-screen flex items-center justify-center relative overflow-hidden">
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl mt-16 lg:mt-0">
            <div class="flex flex-wrap lg:flex-nowrap items-center justify-between gap-12">
                
                <div class="w-full lg:w-1/2 text-center lg:text-left z-10 flex flex-col justify-center">
                    <h2 class="font-bold text-[var(--color-success)] mb-2 text-sm tracking-wider uppercase">Atos 2:42</h2>
                    <h1 class="font-bold text-2xl lg:text-3xl leading-snug text-gray-900 dark:text-white mb-8">
                        "E perseveravam na doutrina dos apóstolos, na comunhão, no partir do pão e nas orações"
                    </h1>
                </div>
                
                <div class="w-full lg:w-1/2 z-10 flex justify-center lg:justify-end">
                    <div class="w-full max-w-lg aspect-video rounded-xl shadow-xl overflow-hidden ring-2 ring-white/20 bg-black">
                        <iframe title="YouTube video player" class="w-full h-full" allowfullscreen="" src="https://www.youtube.com/embed/CMwYG1snm3U?autoplay=1&mute=1&loop=1&playlist=CMwYG1snm3U"></iframe>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Scroll indicator -->
        <a aria-label="Role para baixo" href="#sobre-nos" class="absolute bottom-10 left-1/2 transform -translate-x-1/2 flex flex-col items-center animate-bounce text-gray-400 hover:text-[var(--color-brand)] dark:text-gray-500 dark:hover:text-white select-none hidden lg:flex cursor-pointer no-underline transition-colors">
            <span class="text-xs uppercase tracking-widest mb-1 font-semibold">Role Para Baixo</span>
            <i class="fa-solid fa-chevron-down text-lg"></i>
        </a>
    </header>

    <section id="sobre-nos" class="py-20 relative bg-white dark:bg-slate-900 transition-colors">
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
            <div class="text-center max-w-2xl mx-auto mb-16 scroll-card">
                <p class="font-bold text-[var(--color-success)] mb-2 uppercase tracking-wide text-xs">Um pouco mais sobre nossa igreja</p>
                <h3 class="font-extrabold text-2xl lg:text-3xl text-gray-900 dark:text-white">Sobre nós</h3>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
                <div class="bg-gray-50 dark:bg-slate-800 rounded-2xl p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 relative scroll-card border border-gray-100 dark:border-slate-700 group">
                    <div class="absolute top-5 right-5 text-[var(--color-success)] w-10 h-10 flex items-center justify-center bg-white dark:bg-slate-900 rounded-full shadow-sm text-lg group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-users"></i>
                    </div>
                    <h5 class="font-bold text-lg mb-2 pr-12 text-gray-900 dark:text-gray-100">Pastores</h5>
                    <p class="text-gray-500 dark:text-gray-400 text-sm mb-5 line-clamp-2">Conheça nosso quadro pastoral e um pouco sobre cada um dos pastores</p>
                    <a href="/pastores" class="inline-block bg-[var(--color-brand)] text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-[var(--color-brand-dark)] transition-colors shadow-sm">Conheça</a>
                </div>

                <div class="bg-gray-50 dark:bg-slate-800 rounded-2xl p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 relative scroll-card border border-gray-100 dark:border-slate-700 group">
                    <div class="absolute top-5 right-5 text-[var(--color-success)] w-10 h-10 flex items-center justify-center bg-white dark:bg-slate-900 rounded-full shadow-sm text-lg group-hover:scale-110 transition-transform">
                        <i class="fa-regular fa-calendar-check"></i>
                    </div>
                    <h5 class="font-bold text-lg mb-2 pr-12 text-gray-900 dark:text-gray-100">Eventos</h5>
                    <p class="text-gray-500 dark:text-gray-400 text-sm mb-5 line-clamp-2">Tudo que acontece na igreja durante a semana</p>
                    <a href="/programacao" class="inline-block bg-[var(--color-brand)] text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-[var(--color-brand-dark)] transition-colors shadow-sm">Fique por dentro</a>
                </div>

                <div class="bg-gray-50 dark:bg-slate-800 rounded-2xl p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 relative scroll-card border border-gray-100 dark:border-slate-700 group">
                    <div class="absolute top-5 right-5 text-[var(--color-success)] w-10 h-10 flex items-center justify-center bg-white dark:bg-slate-900 rounded-full shadow-sm text-lg group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-book-open"></i>
                    </div>
                    <h5 class="font-bold text-lg mb-2 pr-12 text-gray-900 dark:text-gray-100">O que nós cremos?</h5>
                    <p class="text-gray-500 dark:text-gray-400 text-sm mb-5 line-clamp-2">Saiba um pouco mais sobre a doutrina e visão da nossa igreja</p>
                    <a href="/cremos" class="inline-block bg-[var(--color-brand)] text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-[var(--color-brand-dark)] transition-colors shadow-sm">Saiba mais</a>
                </div>

                <div class="bg-gray-50 dark:bg-slate-800 rounded-2xl p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 relative scroll-card border border-gray-100 dark:border-slate-700 group">
                    <div class="absolute top-5 right-5 text-[var(--color-success)] w-10 h-10 flex items-center justify-center bg-white dark:bg-slate-900 rounded-full shadow-sm text-lg group-hover:scale-110 transition-transform">
                        <i class="fa-regular fa-newspaper"></i>
                    </div>
                    <h5 class="font-bold text-lg mb-2 pr-12 text-gray-900 dark:text-gray-100">História</h5>
                    <p class="text-gray-500 dark:text-gray-400 text-sm mb-5 line-clamp-2">Descubra nossa história, desde a fundação até os dias de hoje.</p>
                    <a href="/historia" class="inline-block bg-[var(--color-brand)] text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-[var(--color-brand-dark)] transition-colors shadow-sm">Leia</a>
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 bg-gray-50 dark:bg-slate-800 transition-colors relative">
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
            <div class="text-center max-w-2xl mx-auto mb-16 scroll-card">
                <p class="font-bold text-[var(--color-success)] mb-2 uppercase tracking-wide text-xs">Acompanhe nossos canais digitais</p>
                <h3 class="font-extrabold text-2xl lg:text-3xl text-gray-900 dark:text-white">Redes sociais</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 scroll-card items-stretch" id="midias">
                
                <div class="w-full flex">
                    <iframe title="Postagem do Instagram" class="rounded-2xl shadow-sm hover:shadow-lg transition-shadow duration-300 w-full" id="insta-frame" src="https://www.instagram.com/p/C5HNDGuOdsB/embed" loading="lazy"></iframe>
                </div>

                <div class="w-full flex">
                    <div class="bg-[#d7e0fd] dark:bg-slate-800 rounded-2xl p-8 flex flex-col items-center justify-center text-center w-full shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 min-h-[340px]">
                        <i class="fa-brands fa-youtube text-[#ff0033] dark:text-[#ff4d6d] text-6xl mb-6"></i>
                        <p class="font-bold text-[#3763f4] dark:text-[#7b98f9] mb-2 uppercase text-sm tracking-wide">Nosso youtube</p>
                        <h5 class="font-bold text-gray-900 dark:text-gray-100 mb-6 text-lg leading-tight">Acompanhe nossos cultos ao vivo, eventos e muito mais</h5>
                        <a href="https://www.youtube.com.br/@1ipimachado" target="_blank" rel="nofollow" class="bg-[#3763f4] text-white px-5 py-2 rounded-md font-medium hover:bg-blue-700 transition inline-block">
                            Assistir
                        </a>
                    </div>
                </div>

                <div class="w-full flex">
                    <div class="bg-[#52a7af]/15 dark:bg-slate-800 rounded-2xl p-8 flex flex-col items-center justify-center text-center w-full shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 min-h-[340px]">
                        <div class="w-16 h-16 bg-[#52a7af] dark:bg-[#6abfc7] rounded-full flex items-center justify-center mb-6">
                            <i class="fa-solid fa-podcast text-white dark:text-slate-900 text-3xl"></i>
                        </div>
                        <p class="font-bold text-[#52a7af] dark:text-[#88c5cb] mb-2 uppercase text-sm tracking-wide">Torre Cast</p>
                        <h5 class="font-bold text-gray-900 dark:text-gray-100 mb-6 text-lg leading-tight">Nosso podcast: convidados especiais e temas diversos</h5>
                        <a href="https://www.youtube.com/@TorreCast" target="_blank" rel="nofollow" class="bg-[#52a7af] text-white px-5 py-2 rounded-md font-medium hover:bg-teal-600 transition inline-block">
                            Ouvir
                        </a>
                    </div>
                </div>

                <div class="w-full flex">
                    <div class="bg-white dark:bg-slate-900 rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 flex flex-col w-full min-h-[340px]">
                        <div class="bg-[#008169] h-[55px] flex items-center px-4 shrink-0">
                            <div class="w-8 h-8 flex items-center justify-center mr-3">
                                <Image alt="Logo da igreja" src="/assets/img/logo_transp.png" class="w-full h-full object-contain drop-shadow-sm" width="32" height="32" />
                            </div>
                            <div class="leading-tight">
                                <h5 class="text-white font-bold text-sm m-0 leading-none">1ipim</h5>
                                <span class="text-white/80 text-xs mt-1 block">online</span>
                            </div>
                        </div>
                        <div class="flex-grow flex flex-col items-center justify-center text-center p-8 bg-cover bg-center relative" style="background-image: url('/assets/img/whatsapp.jpg');">
                            <div class="absolute inset-0 bg-white/90 dark:bg-slate-900/90 backdrop-blur-[2px] transition-colors"></div>
                            <div class="relative z-10 w-full">
                                <p class="font-bold text-[#075e54] dark:text-[#28b4a2] mb-2 uppercase text-sm tracking-wide">Nosso grupo</p>
                                <h5 class="font-bold text-gray-900 dark:text-white mb-6 text-lg leading-tight">Aqui é onde você verá o dia a dia da nossa igreja e as principais notícias</h5>
                                <a href="https://chat.whatsapp.com/HUnj2vU8XRjLDLqQrjZsho" target="_blank" rel="nofollow" class="bg-[#075e54] text-white px-6 py-2 rounded-md font-medium hover:bg-green-800 transition shadow inline-block">
                                    Participar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
