---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

const schedule = [
  {
    day: "Domingo",
    events: [
      {
        title: "Escola Bíblica Dominical",
        tag: "Doutrina",
        tagColor: "#7ccece",
        description: "Às 9:00, no templo. A Escola Bíblica Dominical (EBD) é um ministério de ensino da igreja, dedicado ao estudo sistemático da Bíblia. Ela tem o propósito de instruir crianças, jovens e adultos na fé cristã, promovendo o crescimento espiritual e a aplicação prática das Escrituras na vida diária."
      },
      {
        title: "Culto Solene",
        tag: "Orações",
        tagColor: "#7ace9f",
        description: "Às 19:00, no Templo. O Culto Solene é o momento central de adoração da igreja, onde os crentes se reúnem para glorificar a Deus por meio da oração, do louvor, da pregação da Palavra e da comunhão."
      }
    ]
  },
  {
    day: "Quarta-feira",
    events: [
      {
        title: "Reunião de Oração",
        tag: "Orações",
        tagColor: "#7ace9f",
        description: "Às 18:30, no espaço Get Up, nos reunimos semanalmente com o propósito de orar pela igreja, pelas missões, pelos enfermos e uns pelos outros, fortalecendo a comunhão e a fé da congregação. A prática contínua da oração mantém a igreja centrada na dependência de Deus e no fortalecimento espiritual de todos os membros, sendo o pilar sustentador de todos os demais ministérios da igreja."
      }
    ]
  },
  {
    day: "Sábado",
    events: [
      {
        title: "Get Up",
        link: "https://www.instagram.com/juventude_getup/",
        tag: "Comunhão",
        tagColor: "#6fc7b0",
        description: "Às 19:30, no Espaço Get Up, o Get Up, ministério de jovens da igreja, se reúne para louvar a Deus, estudar Sua Palavra e ter um tempo de comunhão entre os irmãos. É um ministério dedicado ao fortalecimento espiritual dos jovens, buscando crescer na fé e no serviço a Deus."
      }
    ]
  }
];


---
<Layout title="Programação - Primeira Igreja Presbiteriana Independente de Machado">
    <section class="py-20 mt-16 bg-white dark:bg-slate-900 transition-colors min-h-screen">
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
            <div class="text-center max-w-2xl mx-auto mb-16 scroll-card">
                <h2 class="font-extrabold text-3xl md:text-4xl text-gray-900 dark:text-white mb-2">Nossa programação</h2>
                <p class="text-gray-500 dark:text-gray-400 text-lg">Confira todos os eventos que acontecem na nossa igreja</p>
            </div>
            
            <div class="flex flex-col lg:flex-row gap-8 items-start">
                <!-- Schedule Column -->
                <div class="w-full lg:w-3/4">
                    <div class="bg-gray-50/50 dark:bg-slate-800/20 rounded-[2.5rem] p-6 md:p-10 shadow-sm border border-gray-100 dark:border-slate-700 flex flex-col space-y-12">
                        {schedule.map(group => (
                            <div class="scroll-card relative">
                                <h3 class="font-extrabold text-3xl text-gray-900 dark:text-white mb-8 flex items-center gap-4">
                                    <span class="w-14 h-14 rounded-2xl bg-white dark:bg-slate-800 flex items-center justify-center shadow-sm border border-gray-100 dark:border-slate-700 shrink-0 text-xl text-[var(--color-brand)]">
                                        <i class="fa-regular fa-calendar-check text-[var(--color-brand)]"></i>
                                    </span>
                                    {group.day}
                                </h3>
                                <div class="space-y-4 md:pl-18">
                                    {group.events.map(event => (
                                        <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 md:p-8 border border-gray-100 dark:border-slate-700 hover:shadow-xl hover:-translate-y-1 hover:border-[var(--color-brand)]/30 transition-all duration-300 group/event flex flex-col relative overflow-hidden">
                                            <div class="absolute right-0 top-0 w-32 h-32 rounded-full blur-[50px] opacity-10 pointer-events-none group-hover/event:opacity-20 transition-opacity" style={`background-color: ${event.tagColor};`}></div>
                                            <div class="flex items-center gap-3 mb-4 relative z-10">
                                                {(event as any).link ? (
                                                    <a href={(event as any).link} target="_blank" rel="nofollow" class="font-bold text-xl text-gray-900 dark:text-white hover:text-[var(--color-brand)] transition-colors">
                                                        {event.title} <i class="fa-solid fa-arrow-up-right-from-square text-xs opacity-50 ml-1"></i>
                                                    </a>
                                                ) : (
                                                    <h6 class="font-bold text-xl text-gray-900 dark:text-white m-0">{event.title}</h6>
                                                )}
                                                <span class="text-white text-[10px] px-2.5 py-1 rounded font-bold uppercase tracking-wider" style={`background-color: ${event.tagColor};`}>
                                                    {event.tag}
                                                </span>
                                            </div>
                                            <div class="flex items-start gap-4 relative z-10">
                                                <i class="fa-regular fa-clock text-[var(--color-brand)] text-xl mt-0.5 shrink-0 opacity-80"></i>
                                                <p class="text-gray-600 dark:text-gray-300 text-sm md:text-base leading-relaxed">{event.description}</p>
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        ))}
                    </div>
                </div>

                <!-- Lateral Promo Column -->
                <div class="w-full lg:w-1/4 flex flex-col gap-6 lg:sticky lg:top-32">
                    <!-- Promo Eventos Especiais -->
                    <a href="/eventos" class="bg-gradient-to-br from-indigo-500 to-purple-600 rounded-3xl p-6 md:p-8 shadow-lg hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 text-white scroll-card relative overflow-hidden group flex flex-col min-h-[300px]">
                        <div class="absolute right-0 top-0 w-32 h-32 bg-white/20 rounded-full blur-2xl translate-x-1/2 -translate-y-1/2 pointer-events-none group-hover:scale-150 transition-transform duration-700"></div>
                        
                        <div class="relative z-10 flex flex-col flex-1 h-full">
                            <div class="w-12 h-12 bg-white/20 text-white rounded-2xl flex items-center justify-center mb-6 shadow-sm backdrop-blur-sm group-hover:rotate-12 transition-transform group-hover:scale-110">
                                <i class="fa-solid fa-calendar-days text-xl"></i>
                            </div>
                            <h5 class="font-extrabold text-2xl mb-3 leading-tight drop-shadow-md">Eventos & Calendário</h5>
                            <p class="text-white/90 mb-8 text-sm leading-relaxed font-medium">Acampamentos, conferências e congressos imperdíveis marcados pro nosso ano.</p>
                            
                            <div class="mt-auto inline-flex items-center justify-center gap-2 font-extrabold text-sm tracking-wide uppercase bg-white/10 group-hover:bg-white text-white group-hover:text-indigo-600 px-4 py-3.5 rounded-xl transition-all duration-300 w-full border border-white/20 shadow-sm text-center">
                                Ver eventos <i class="fa-solid fa-arrow-right ml-1"></i>
                            </div>
                        </div>
                    </a>
                    
                    <!-- PGs -->
                    <div class="bg-gradient-to-br from-[var(--color-brand)] to-[var(--color-brand-dark)] rounded-3xl p-6 md:p-8 shadow-lg hover:shadow-xl transition-shadow text-white scroll-card relative overflow-hidden group flex flex-col min-h-[250px]">
                        <div class="absolute -right-4 -bottom-4 text-white/10 text-8xl group-hover:scale-110 group-hover:-rotate-12 transition-transform duration-500">
                            <i class="fa-solid fa-users"></i>
                        </div>
                        <div class="relative z-10 flex-1 flex flex-col h-full">
                            <h5 class="font-extrabold text-2xl mb-3 drop-shadow-md">Pequenos grupos</h5>
                            <p class="text-white/90 mb-8 text-sm leading-relaxed font-medium">
                                Diversos grupos pela cidade. Encontre o mais próximo de sua casa ou faixa etária!
                            </p>
                            <a href="/pg" class="mt-auto inline-flex items-center justify-center gap-2 bg-white text-[var(--color-brand)] px-6 py-3.5 rounded-xl font-bold hover:scale-105 transition-transform shadow-md w-full text-sm text-center">
                                Conhecer Grupos <i class="fa-solid fa-arrow-right ml-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>


