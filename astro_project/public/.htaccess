# Cache Control para Otimização de Performance
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Imagens e Ícones
    ExpiresByType image/jpg "access plus 7 days"
    ExpiresByType image/jpeg "access plus 7 days"
    ExpiresByType image/gif "access plus 7 days"
    ExpiresByType image/png "access plus 7 days"
    ExpiresByType image/webp "access plus 7 days"
    ExpiresByType image/svg+xml "access plus 7 days"
    ExpiresByType image/x-icon "access plus 7 days"
    
    # Vídeos
    ExpiresByType video/mp4 "access plus 7 days"
    ExpiresByType video/webm "access plus 7 days"
    
    # Fontes
    ExpiresByType font/ttf "access plus 1 month"
    ExpiresByType font/otf "access plus 1 month"
    ExpiresByType font/woff "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 month"
    
    # CSS e Javascript
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    
    # Padrão
    ExpiresDefault "access plus 2 days"
</IfModule>

<IfModule mod_headers.c>
    # Adiciona Header Cache-Control
    <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|js|css|swf|webp|mp4|webm)$">
        Header set Cache-Control "max-age=604800, public"
    </FilesMatch>
    
    # Habilitar Compressão Gzip se disponível
    <IfModule mod_deflate.c>
        AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
    </IfModule>
</IfModule>
