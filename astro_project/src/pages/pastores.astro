---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

const pastores = [
  {
    name: "Marinaldo",
    role: "Partir do Pão",
    roleColor: "#b8e466",
    image: "/assets/img/pastores/marinaldo.jpg",
    bio: "Bacharel em Teologia pelo Seminário Teológico Presbiteriano Rev. Denoel Nicodemos Eller, em Belo Horizonte, e pós-graduando em Teologia Reformada pelo Instituto Reformado de São Paulo. Presidente da Missão Vida Nova, instituição de recuperação para dependentes químicos, e responsável pelo projeto de implantação da Oitava Igreja Presbiteriana Independente de Machado. Preside o conselho da igreja e lidera os ministérios \"Partir o Pão\", apoiando órfãos, viúvas, pobres e enfermos da igreja, além de exercer o cuidado diaconal e missionário. Casado com Keiler e pai de Sarah e Johannes."
  },
  {
    name: "Sebastião Arruda",
    role: "Doutrina",
    roleColor: "#7ccece",
    image: "/assets/img/pastores/Arruda.jpg",
    bio: "Formado em Teologia pelo Seminário Presbiteriano Conservador e mestre em Teologia com especialização em Hebraico e Antigo Testamento pelo Centro de Pós-graduação Andrew Jumper. Ordenado em 1984, foi revisor na Casa Editora Cultura Cristã e editor do Jornal “O Presbiteriano Conservador”. Lecionou no Seminário Presbiteriano José Manoel da Conceição (JMC) e no Seminário Presbiteriano Conservador, nas áreas de Hebraico, Exegese do Antigo Testamento e Teologia Bíblica, e como professor convidado no SETECEB e SPR em Anápolis, GO. É pastor jubilado da Igreja Presbiteriana Conservadora e fundador do Projeto Edukáris em Machado, MG. Atualmente atua como pastor auxiliar, supervisionando os ministérios doutrinários da igreja, como a EBD, a Superintendência de Ensino, a Junta Teológica, entre outros. Casado com Miriam e pai de Mateus e Priscila."
  },
  {
    name: "Fellipe Conti",
    role: "Comunhão",
    roleColor: "#6fc7b0",
    image: "/assets/img/pastores/Conti.jpg",
    bio: "Evangelista da Primeira Igreja Presbiteriana Independente de Machado - MG, líder do ministério de jovens GetUp, presidente do Acampamento Maanaim e supervisor de pequenos grupos da igreja. Também é responsável pelo Torrecast - podcast da igreja - e os demais ministérios de comunhão. É graduado em Administração de Empresas e está atualmente graduando-se na Faculdade de Teologia de São Paulo (FATIPI) e no Instituto CREIA de Machado-MG. Fellipe é casado com Ana Paula e pai de Tito e Rute."
  },
  {
    name: "Rubens Luz",
    role: "Orações",
    roleColor: "#7ace9f",
    image: "/assets/img/pastores/Rubens.png",
    bio: "Bacharel em teologia com concentração em Educação Cristã pelo Seminário Bíblico Palavra da Vida. Licenciado em Pedagogia pela Faculdade Campos Salles. Mestre em Educação pela Universidade Presbiteriana Mackenzie. É missionário da SEPAL (Servindo Pastores e Líderes) e integra a lideraçã dos ministérios LIMIAR e T-LINK. Atua como pastor auxiliar, sendo responsável pela vida de oração da igreja e pelo cuidado pastoral. Preside a secretaria de missões e o Instituto Creia, entre outros. Rubens é casado com Evana e pai."
  }
];
---
<Layout title="Pastores - Primeira Igreja Presbiteriana Independente de Machado">
    <section class="py-20 mt-16 bg-white dark:bg-slate-900 transition-colors min-h-screen">
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
            <div class="text-center max-w-2xl mx-auto mb-16 scroll-card">
                <h2 class="font-extrabold text-3xl md:text-4xl text-gray-900 dark:text-white mb-2">Nossos Pastores</h2>
                <p class="text-gray-500 dark:text-gray-400 text-lg">E perseveravam...</p>
            </div>
            
            <div class="max-w-4xl mx-auto space-y-12">
                {pastores.map(pastor => (
                    <div class="bg-gray-50/50 dark:bg-slate-800/80 rounded-[2.5rem] p-8 md:p-12 shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-500 border border-gray-100 dark:border-slate-700 scroll-card relative overflow-hidden group">
                        <!-- Cor dinámica no fundo de cada Bento Box -->
                        <div class="absolute right-0 top-0 w-64 h-64 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/2 pointer-events-none opacity-20 group-hover:opacity-40 transition-opacity duration-700" style={`background-color: ${pastor.roleColor};`}></div>
                        
                        <div class="flex flex-col md:flex-row items-center md:items-start gap-10 relative z-10">
                            <div class="shrink-0 relative group/img">
                                <div class="w-[180px] h-[180px] md:w-[220px] md:h-[220px] rounded-[2rem] overflow-hidden shadow-xl border-4 border-white dark:border-slate-700 z-10 relative">
                                    <Image src={pastor.image} alt={pastor.name} class="w-full h-full object-cover group-hover/img:scale-110 transition-transform duration-700" width={400} height={400} />
                                </div>
                                <div class="absolute inset-0 bg-black/10 dark:bg-black/50 rounded-[2rem] blur-xl -z-10 translate-y-4"></div>
                            </div>
                            <div class="flex-1 text-center md:text-left">
                                <h5 class="font-extrabold text-3xl md:text-4xl text-gray-900 dark:text-white mb-3">{pastor.name}</h5>
                                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-6 font-bold text-sm text-gray-900 shadow-sm transition-transform hover:scale-105" style={`background-color: ${pastor.roleColor};`}>
                                    <i class="fa-solid fa-crosshairs opacity-70"></i>{pastor.role}
                                </div>
                                <p class="text-gray-600 dark:text-gray-300 leading-relaxed text-sm md:text-base text-justify md:text-left selection:bg-[var(--color-brand)] selection:text-white">{pastor.bio}</p>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section class="py-20 bg-gray-50 dark:bg-slate-800 transition-colors">
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
            <div class="text-center max-w-3xl mx-auto mb-12 scroll-card">
                <h2 class="font-extrabold text-3xl text-gray-900 dark:text-white mb-4">Pilares ministeriais</h2>
                <p class="text-gray-600 dark:text-gray-400 text-lg">Confira como as responsabilidades ministeriais da nossa igreja são divididas, de acordo com os quatro pilares de Atos 2.42</p>
            </div>
            
            <!-- Bento Grid dos 4 Pilares -->
            <div class="max-w-5xl mx-auto mb-16">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

                    <!-- Pilar 1: Doutrina dos Apóstolos -->
                    <div class="group relative bg-white dark:bg-slate-900 rounded-[2.5rem] p-8 md:p-10 shadow-lg border border-gray-100 dark:border-slate-700 hover:-translate-y-2 hover:shadow-2xl transition-all duration-500 scroll-card overflow-hidden flex flex-col">
                        <div class="absolute right-0 top-0 w-48 h-48 rounded-full blur-[60px] -translate-y-1/2 translate-x-1/2 pointer-events-none opacity-20 group-hover:opacity-40 transition-opacity duration-700" style="background-color:#7ccece;"></div>
                        <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-6 shadow-sm group-hover:scale-110 transition-transform relative z-10" style="background-color:#7ccece22; color:#3aabac;">
                            <i class="fa-solid fa-scroll"></i>
                        </div>
                        <div class="relative z-10 flex-1 flex flex-col">
                            <p class="font-bold uppercase tracking-widest text-[10px] mb-2 opacity-60 text-gray-500 dark:text-gray-400">Atos 2.42 — 1º Pilar</p>
                            <h4 class="font-extrabold text-2xl text-gray-900 dark:text-white mb-3 leading-tight">Doutrina dos<br/>Apóstolos</h4>
                            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed flex-1">Ensino sistemático e expositivo da Palavra de Deus: EBD, Superintendência de Ensino, Junta Teológica e ministérios teológicos da igreja.</p>
                            <div class="mt-6 flex items-center gap-3 pt-4 border-t border-gray-100 dark:border-slate-700">
                                <div class="w-9 h-9 rounded-full overflow-hidden border-2 border-white dark:border-slate-600 shadow-sm shrink-0">
                                    <Image src="/assets/img/pastores/Arruda.jpg" alt="Pr. Sebastião Arruda" width={40} height={40} class="w-full h-full object-cover" />
                                </div>
                                <span class="text-xs font-bold text-gray-700 dark:text-gray-300">Responsável: <span style="color:#3aabac;">Pr. Sebastião Arruda</span></span>
                            </div>
                        </div>
                    </div>

                    <!-- Pilar 2: Comunhão -->
                    <div class="group relative bg-white dark:bg-slate-900 rounded-[2.5rem] p-8 md:p-10 shadow-lg border border-gray-100 dark:border-slate-700 hover:-translate-y-2 hover:shadow-2xl transition-all duration-500 scroll-card overflow-hidden flex flex-col">
                        <div class="absolute right-0 top-0 w-48 h-48 rounded-full blur-[60px] -translate-y-1/2 translate-x-1/2 pointer-events-none opacity-20 group-hover:opacity-40 transition-opacity duration-700" style="background-color:#6fc7b0;"></div>
                        <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-6 shadow-sm group-hover:scale-110 transition-transform relative z-10" style="background-color:#6fc7b022; color:#3aab91;">
                            <i class="fa-solid fa-users"></i>
                        </div>
                        <div class="relative z-10 flex-1 flex flex-col">
                            <p class="font-bold uppercase tracking-widest text-[10px] mb-2 opacity-60 text-gray-500 dark:text-gray-400">Atos 2.42 — 2º Pilar</p>
                            <h4 class="font-extrabold text-2xl text-gray-900 dark:text-white mb-3 leading-tight">Comunhão</h4>
                            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed flex-1">Pequenos Grupos, Ministério Jovem GetUp, Acampamento Maanaim, TorreCast e todos os ministérios de conexão e relacionamento da Igreja.</p>
                            <div class="mt-6 flex items-center gap-3 pt-4 border-t border-gray-100 dark:border-slate-700">
                                <div class="w-9 h-9 rounded-full overflow-hidden border-2 border-white dark:border-slate-600 shadow-sm shrink-0">
                                    <Image src="/assets/img/pastores/Conti.jpg" alt="Ev. Fellipe Conti" width={40} height={40} class="w-full h-full object-cover" />
                                </div>
                                <span class="text-xs font-bold text-gray-700 dark:text-gray-300">Responsável: <span style="color:#3aab91;">Ev. Fellipe Conti</span></span>
                            </div>
                        </div>
                    </div>

                    <!-- Pilar 3: Partir do Pão -->
                    <div class="group relative bg-white dark:bg-slate-900 rounded-[2.5rem] p-8 md:p-10 shadow-lg border border-gray-100 dark:border-slate-700 hover:-translate-y-2 hover:shadow-2xl transition-all duration-500 scroll-card overflow-hidden flex flex-col">
                        <div class="absolute right-0 top-0 w-48 h-48 rounded-full blur-[60px] -translate-y-1/2 translate-x-1/2 pointer-events-none opacity-20 group-hover:opacity-40 transition-opacity duration-700" style="background-color:#b8e466;"></div>
                        <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-6 shadow-sm group-hover:scale-110 transition-transform relative z-10" style="background-color:#b8e46622; color:#7daf0e;">
                            <i class="fa-solid fa-bread-slice"></i>
                        </div>
                        <div class="relative z-10 flex-1 flex flex-col">
                            <p class="font-bold uppercase tracking-widest text-[10px] mb-2 opacity-60 text-gray-500 dark:text-gray-400">Atos 2.42 — 3º Pilar</p>
                            <h4 class="font-extrabold text-2xl text-gray-900 dark:text-white mb-3 leading-tight">Partir do Pão</h4>
                            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed flex-1">Cuidado diaconal e missionário: apoio a órfãos, viúvas, enfermos e pobres da comunidade, além do projeto de implantação de novas igrejas.</p>
                            <div class="mt-6 flex items-center gap-3 pt-4 border-t border-gray-100 dark:border-slate-700">
                                <div class="w-9 h-9 rounded-full overflow-hidden border-2 border-white dark:border-slate-600 shadow-sm shrink-0">
                                    <Image src="/assets/img/pastores/marinaldo.jpg" alt="Pr. Marinaldo" width={40} height={40} class="w-full h-full object-cover" />
                                </div>
                                <span class="text-xs font-bold text-gray-700 dark:text-gray-300">Responsável: <span style="color:#7daf0e;">Pr. Marinaldo</span></span>
                            </div>
                        </div>
                    </div>

                    <!-- Pilar 4: Orações -->
                    <div class="group relative bg-white dark:bg-slate-900 rounded-[2.5rem] p-8 md:p-10 shadow-lg border border-gray-100 dark:border-slate-700 hover:-translate-y-2 hover:shadow-2xl transition-all duration-500 scroll-card overflow-hidden flex flex-col">
                        <div class="absolute right-0 top-0 w-48 h-48 rounded-full blur-[60px] -translate-y-1/2 translate-x-1/2 pointer-events-none opacity-20 group-hover:opacity-40 transition-opacity duration-700" style="background-color:#7ace9f;"></div>
                        <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-6 shadow-sm group-hover:scale-110 transition-transform relative z-10" style="background-color:#7ace9f22; color:#29a060;">
                            <i class="fa-solid fa-hands-praying"></i>
                        </div>
                        <div class="relative z-10 flex-1 flex flex-col">
                            <p class="font-bold uppercase tracking-widest text-[10px] mb-2 opacity-60 text-gray-500 dark:text-gray-400">Atos 2.42 — 4º Pilar</p>
                            <h4 class="font-extrabold text-2xl text-gray-900 dark:text-white mb-3 leading-tight">Orações</h4>
                            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed flex-1">Vida de oração da Igreja, cuidado pastoral, Secretaria de Missões e Instituto CREIA — formando intercessores e enviando missionários.</p>
                            <div class="mt-6 flex items-center gap-3 pt-4 border-t border-gray-100 dark:border-slate-700">
                                <div class="w-9 h-9 rounded-full overflow-hidden border-2 border-white dark:border-slate-600 shadow-sm shrink-0">
                                    <Image src="/assets/img/pastores/Rubens.png" alt="Pr. Rubens Luz" width={40} height={40} class="w-full h-full object-cover" />
                                </div>
                                <span class="text-xs font-bold text-gray-700 dark:text-gray-300">Responsável: <span style="color:#29a060;">Pr. Rubens Luz</span></span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
            
            <div class="text-center scroll-card">
                <a href="https://wa.me/5535988613046" target="_blank" rel="nofollow" class="inline-flex items-center gap-3 bg-[var(--color-brand)] text-white px-10 py-5 rounded-full font-extrabold hover:bg-[var(--color-brand-dark)] transition-colors shadow-lg hover:shadow-2xl hover:-translate-y-1 active:translate-y-0 text-lg">
                    Entre em contato com a equipe <i class="fa-brands fa-whatsapp text-2xl"></i>
                </a>
            </div>
        </div>
    </section>
</Layout>
