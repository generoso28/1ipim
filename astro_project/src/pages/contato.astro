---
import Layout from '../layouts/Layout.astro';

const congregacoes = [
    { name: "Santa Luíza", address: "R. Ituiutaba, 58", city: "Santa Luiza, Machado-MG" },
    { name: "Jardim das Oliveiras", address: "R. Augusto Buzatti Filho, 204", city: "Jd. das Oliveiras, Machado-MG" },
    { name: "Santo Antônio II", address: "R. José Cândido de Souza Dias,", city: "Santo Antônio II, Machado-MG" },
    { name: "Serrania", address: "R. Cel. Antônio Faustino, 450", city: "Serrania-MG" },
    { name: "Paraguaçu", address: "Av. Dr. Domingos Condé, 70", city: "Parque dos Pinheiros, Paraguaçu-MG" },
    { name: "Carvalhópolis", address: "R. Marcolino Pereira de Carvalho, 385", city: "Carvalhópolis-MG" },
    { name: "Pouso Alegre", address: "R. Coronel José Inacio, 290", city: "Jardim Noronha, Pouso Alegre-MG" }
];
---
<Layout title="Contato - Primeira Igreja Presbiteriana Independente de Machado" footerBgClass="bg-white dark:bg-slate-900">
    <section class="py-20 mt-16 bg-white dark:bg-slate-900 transition-colors min-h-screen">
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
            <div class="text-center max-w-2xl mx-auto mb-16 scroll-card">
                <p class="font-bold text-[var(--color-success)] mb-2 uppercase tracking-wide text-sm">Contato</p>
                <h2 class="font-extrabold text-3xl md:text-4xl text-gray-900 dark:text-white mb-2">Saiba como entrar em contato</h2>
            </div>

            <div class="flex flex-col lg:flex-row gap-8 mb-16">
                <!-- Sede Contact Info -->
                <div class="w-full lg:w-1/3 bg-white dark:bg-slate-800 rounded-[2.5rem] p-10 lg:p-12 border border-gray-100 dark:border-slate-700 shadow-xl scroll-card flex flex-col relative overflow-hidden group">
                    <div class="absolute right-0 top-0 w-64 h-64 bg-[var(--color-success)]/10 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/2 pointer-events-none group-hover:scale-150 transition-transform duration-1000"></div>
                    <div class="relative z-10 flex-1">
                        <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white mb-10">Sede</h2>
                        
                        <div class="space-y-10">
                            <div class="flex items-start gap-5">
                                <div class="w-14 h-14 rounded-2xl bg-[var(--color-success)]/10 dark:bg-[var(--color-success)]/20 text-[var(--color-success)] dark:text-[var(--color-success-light)] flex items-center justify-center shrink-0 shadow-sm group-hover:scale-110 transition-transform">
                                    <i class="fa-solid fa-phone text-xl"></i>
                                </div>
                                <div>
                                    <h6 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm uppercase tracking-wide">Telefone</h6>
                                    <p class="text-gray-600 dark:text-gray-300 m-0 leading-relaxed">(35) 98861-3046</p>
                                </div>
                            </div>

                            <div class="flex items-start gap-5">
                                <div class="w-14 h-14 rounded-2xl bg-[var(--color-success)]/10 dark:bg-[var(--color-success)]/20 text-[var(--color-success)] dark:text-[var(--color-success-light)] flex items-center justify-center shrink-0 shadow-sm group-hover:scale-110 transition-transform">
                                    <i class="fa-solid fa-envelope text-xl"></i>
                                </div>
                                <div>
                                    <h6 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm uppercase tracking-wide">Email</h6>
                                    <p class="text-gray-600 dark:text-gray-300 m-0"><a href="mailto:secretaria1ipi@gmail.com" class="hover:text-[var(--color-success)] transition-colors">secretaria1ipi@gmail.com</a></p>
                                </div>
                            </div>

                            <div class="flex items-start gap-5">
                                <div class="w-14 h-14 rounded-2xl bg-[var(--color-success)]/10 dark:bg-[var(--color-success)]/20 text-[var(--color-success)] dark:text-[var(--color-success-light)] flex items-center justify-center shrink-0 shadow-sm group-hover:scale-110 transition-transform">
                                    <i class="fa-solid fa-location-dot text-xl"></i>
                                </div>
                                <div>
                                    <h6 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm uppercase tracking-wide">Endereço</h6>
                                    <p class="text-gray-600 dark:text-gray-300 m-0 leading-relaxed">R. Airton Rodrigues Leite, 26 - Centro<br/>Machado, MG</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Google Maps -->
                <div class="w-full lg:w-2/3 h-[450px] lg:h-auto min-h-[450px] rounded-[2.5rem] overflow-hidden shadow-xl border border-gray-100 dark:border-slate-700 scroll-card">
                    <iframe title="Mapa de localização" class="w-full h-full" src="https://maps.google.com/maps?width=100%25&amp;height=100%25&amp;hl=en&amp;q=Rua%20Airton%20Rodrigues%20Leite,%2026&amp;t=&amp;z=17&amp;ie=UTF8&amp;iwloc=B&amp;output=embed"></iframe>
                </div>
            </div>

            <div class="mt-16">
                <h3 class="font-extrabold text-3xl text-gray-900 dark:text-white mb-10 text-center scroll-card">Nossas Congregações</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-6">
                    {congregacoes.map(cong => (
                        <div class="bg-gray-50 dark:bg-slate-800 rounded-[2rem] p-8 border border-gray-100 dark:border-slate-700 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all scroll-card flex flex-col h-full group relative overflow-hidden">
                            <div class="absolute -right-4 -bottom-4 text-[var(--color-success)]/5 text-7xl group-hover:scale-125 transition-transform duration-500 pointer-events-none">
                                <i class="fa-solid fa-church"></i>
                            </div>
                            <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6 group-hover:text-[var(--color-success)] transition-colors relative z-10">{cong.name}</h2>
                            <div class="mt-auto relative z-10">
                                <h6 class="font-bold text-[var(--color-success)] text-[10px] mb-1 uppercase tracking-widest">Endereço</h6>
                                <p class="text-gray-600 dark:text-gray-400 text-sm mb-0 leading-relaxed">{cong.address}<br/>{cong.city}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>

        </div>
    </section>
</Layout>
