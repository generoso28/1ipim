---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

const pgs = [
  { name: "Porção de fé", image: "/assets/img/pgs/porçao-de-fe.jpeg", publico: "Mulheres", responsavel: "Rita e Mayra", horario: "Segunda-feira às 19:30", frequencia: "Quinzenal" },
  { name: "Koinonia", image: "/assets/img/pgs/koinonia.jpeg", publico: "Mulheres", responsavel: "Milka", horario: "Terça-feira às 14:00", frequencia: "Semanal" },
  { name: "Peniel", image: "/assets/img/pgs/PG.png", publico: "Mulheres", responsavel: "Ester", horario: "Terça-feira às 14:30", frequencia: "Semanal" },
  { name: "Entre Meninas e Deus", image: "/assets/img/pgs/entre-meninas-e-Deus.jpeg", publico: "Meninas de 9 a 11 anos", responsavel: "Tati, Thays, Manuela e Anne", horario: "Terça-feira às 19:00", frequencia: "Semanal" },
  { name: "Entre Meninas e Deus", image: "/assets/img/pgs/entre-meninas-e-Deus.jpeg", publico: "Meninas de 12 a 14 anos", responsavel: "Iara, Cris e Fabi", horario: "Terça-feira às 19:00", frequencia: "Semanal" },
  { name: "PG dos meninos", image: "/assets/img/pgs/pg-pedro.jpeg", publico: "Pré-adolescência e juventude", responsavel: "Pedro Luz e Davi Bertelli", horario: "Terça-feira às 19:30", frequencia: "Semanal" },
  { name: "PG Online", image: "/assets/img/pgs/pg-online.jpeg", publico: "Estudantes que moram fora", responsavel: "Lucas Generoso, Lucas Sodré e Nathan", horario: "Terça-feira às 21:30", frequencia: "Semanal" },
  { name: "PG das meninas", image: "/assets/img/pgs/pg-lara.jpeg", publico: "Juventude", responsavel: "Larah e Alicia", horario: "Quarta-feira às 19:30", frequencia: "Semanal" },
  { name: "Mulheres com Propósito", image: "/assets/img/pgs/mulheres-com-proposito.jpeg", publico: "Mulheres acima de 30 anos", responsavel: "Karina e Maressa", horario: "Quinta-feira às 19:30", frequencia: "Semanal" },
  { name: "Famílias em Cristo", image: "/assets/img/pgs/pg-da-familia.jpeg", publico: "Casais", responsavel: "Rodrigo Coelho e Lucyara", horario: "Quinta-feira às 19:30", frequencia: "Semanal" },
  { name: "PG Enrico", image: "/assets/img/pgs/pg-enrico.jpeg", publico: "Jovens/Adultos", responsavel: "Enrico", horario: "Quinta-feira às 19:30", frequencia: "Semanal" },
  { name: "Guerreiros", image: "/assets/img/pgs/pg-homens-rubens-site.png", publico: "Homens", responsavel: "Pr. Arruda e Pr. Rubens", horario: "Quinta-feira às 19:30", frequencia: "Quinzenal" },
  { name: "Florescer", image: "/assets/img/pgs/florescer.jpeg", publico: "Jovens adultas", responsavel: "Paulinha, Sandrinha e Eluan", horario: "Quinta-feira às 19:30", frequencia: "Semanal" },
  { name: "Casa de oração", image: "/assets/img/pgs/pg-eliza.jpeg", publico: "Mulheres", responsavel: "Eliza", horario: "Sexta-feira às 19:15", frequencia: "Quinzenal" },
  { name: "PG Toshiba", image: "/assets/img/pgs/pg-toshiba.jpeg", publico: "Casais", responsavel: "Pr. Arruda", horario: "Sexta-feira às 19:30", frequencia: "Semanal" }
];
---
<Layout title="Pequenos Grupos - Primeira Igreja Presbiteriana Independente de Machado">
    <section class="py-20 mt-16 bg-white dark:bg-slate-900 transition-colors min-h-screen">
        <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
            <div class="text-center max-w-2xl mx-auto mb-16 scroll-card">
                <h2 class="font-extrabold text-3xl md:text-4xl text-gray-900 dark:text-white mb-2">Nossos Pequenos Grupos</h2>
                <p class="text-gray-500 dark:text-gray-400 text-lg">A vida cristã é feita em comunidade. Encontre o grupo que mais se adequa ao seu momento.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {pgs.map(pg => (
                    <div class="rounded-3xl border border-gray-200 dark:border-slate-700/50 shadow-lg hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 overflow-hidden flex flex-col scroll-card group relative min-h-[480px]">
                        <div class="absolute inset-0 z-0">
                            <Image src={pg.image} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000 opacity-90 dark:opacity-70" alt={pg.name} loading="lazy" width={800} height={800} />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/40 to-black/10"></div>
                        </div>
                        <div class="p-6 md:p-8 flex flex-col flex-1 relative z-10 justify-end">
                            <h5 class="font-extrabold text-3xl text-white mb-6 drop-shadow-md">{pg.name}</h5>
                            <div class="space-y-2 mt-auto bg-black/40 backdrop-blur-md rounded-2xl p-5 border border-white/10 group-hover:bg-black/50 transition-colors">
                                <p class="text-xs text-gray-300 flex justify-between border-b border-white/10 pb-2"><strong class="text-white uppercase tracking-wider text-[10px]">Público</strong> <span class="text-right">{pg.publico}</span></p>
                                <p class="text-xs text-gray-300 flex justify-between border-b border-white/10 pb-2 pt-1"><strong class="text-white uppercase tracking-wider text-[10px]">Líder</strong> <span class="text-right">{pg.responsavel}</span></p>
                                <p class="text-xs text-gray-300 flex justify-between border-b border-white/10 pb-2 pt-1"><strong class="text-white uppercase tracking-wider text-[10px]">Horário</strong> <span class="text-right">{pg.horario}</span></p>
                                <p class="text-xs text-gray-300 flex justify-between pt-1 mb-2 items-center"><strong class="text-white uppercase tracking-wider text-[10px]">Frequência</strong> <span class="bg-[var(--color-brand)] text-white px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wide">{pg.frequencia}</span></p>
                                <a href={`https://wa.me/5535988613046?text=Ol%C3%A1%2C%20gostaria%20de%20saber%20mais%20sobre%20o%20Pequeno%20Grupo:%20${pg.name}`} target="_blank" rel="nofollow" class="mt-4 block w-full text-center bg-white text-gray-900 py-3 rounded-xl font-bold hover:bg-gray-200 transition-colors text-sm shadow">
                                    Tenho interesse
                                </a>
                            </div>
                        </div>
                    </div>
                ))}
            </div>

            <div class="mt-20">
                <hr class="border-gray-100 dark:border-slate-800 mb-16 hidden">
                <div class="text-center bg-gradient-to-br from-[#128C7E] to-[#25D366] text-white rounded-[2.5rem] md:rounded-[4rem] p-10 md:p-16 shadow-2xl max-w-5xl mx-auto scroll-card overflow-hidden relative group">
                    <div class="absolute -right-8 -bottom-8 text-black/10 text-[12rem] group-hover:scale-110 group-hover:rotate-12 transition-transform duration-700 pointer-events-none">
                        <i class="fa-brands fa-whatsapp"></i>
                    </div>
                    <div class="relative z-10 flex flex-col items-center">
                        <div class="w-20 h-20 bg-white/20 rounded-full flex items-center justify-center mb-6 backdrop-blur shadow-sm group-hover:scale-110 transition-transform">
                            <i class="fa-brands fa-whatsapp text-4xl"></i>
                        </div>
                        <h4 class="font-extrabold text-3xl md:text-5xl mb-6 leading-tight">Quer saber mais?</h4>
                        <p class="text-white/90 mb-10 max-w-2xl mx-auto text-lg leading-relaxed font-medium">Não importa sua idade ou onde você mora, sempre tem um grupo esperando de braços abertos. Fale com nossa secretaria e encontre o seu lugar.</p>
                        <a href="https://wa.me/5535988613046" target="_blank" rel="nofollow" class="inline-flex items-center gap-3 bg-white text-[#128C7E] px-10 py-5 rounded-full font-extrabold hover:scale-105 transition-transform shadow-xl">
                            Chamar no WhatsApp <i class="fa-solid fa-arrow-right text-sm"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
